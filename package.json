{
  "name": "cursor-noir",
  "displayName": "Cursor Noir",
  "description": "Cursor Dark theme ported from Cursor IDE for VSCode.",
  "version": "1.0.2",
  "publisher": "lhacenmed",
  "engines": {
    "vscode": ">=1.0.0"
  },
  "categories": [
    "Themes"
  ],
  "icon": "./images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lhacenmed/cursor-noir"
  },
  "contributes": {
    "themes": [
      {
        "label": "Cursor Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/cursor-dark.json"
      },
      {
        "label": "Cursor Dark Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/cursor-dark-midnight.json"
      },
      {
        "label": "Cursor Dark Midnight High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/cursor-dark-midnight-high-contrast.json"
      },
      {
        "label": "Cursor Light",
        "uiTheme": "vs",
        "path": "./themes/cursor-light.json"
      }
    ]
  },
  "license": "MIT",
  "dependencies": {
    "release-please": "^17.3.0"
  }
}
